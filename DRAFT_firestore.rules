rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- User Rules ---
    match /users/{userId} {
      allow read: if isSignedIn(); // Basic profiles are public, but email should be guarded if PII isolation is strict
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'skills', 'averageRating', 'totalReviews']);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 50)) &&
             (data.role in ['seeker', 'provider', 'admin']) &&
             (data.skills == null || (data.skills is list && data.skills.size() <= 20)) &&
             (data.totalReviews == null || data.totalReviews is number) &&
             (data.averageRating == null || data.averageRating is number);
    }

    // --- Service Rules ---
    match /services/{serviceId} {
      allow read: if true; // Service listings are public
      allow create: if isSignedIn() && isValidService(incoming()) && incoming().providerId == request.auth.uid;
      allow update: if isSignedIn() && existing().providerId == request.auth.uid && isValidService(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'priceRange']);
      allow delete: if isSignedIn() && existing().providerId == request.auth.uid;
    }

    function isValidService(data) {
      return data.providerId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.category in ['Hardware', 'Software', 'Networking', 'Mobile', 'Other'] &&
             (data.priceRange == null || (data.priceRange is string && data.priceRange.size() <= 50));
    }

    // --- Request Rules ---
    match /requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.seekerId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow create: if isSignedIn() && isValidRequest(incoming()) && incoming().seekerId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Seeker actions
        (existing().seekerId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description', 'updatedAt', 'reviewId']) &&
         (incoming().status == 'cancelled' || existing().status == 'accepted')) ||
        // Provider actions
        (existing().providerId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         (incoming().status in ['accepted', 'in-progress', 'completed', 'cancelled']))
      ) && isValidRequest(incoming());
    }

    function isValidRequest(data) {
      return data.seekerId is string && data.providerId is string && data.serviceId is string &&
             data.status in ['pending', 'accepted', 'in-progress', 'completed', 'cancelled'] &&
             (data.description == null || (data.description is string && data.description.size() <= 500));
    }

    // --- Review Rules ---
    match /reviews/{reviewId} {
      allow read: if true; // Reviews are public
      allow create: if isSignedIn() && isValidReview(incoming()) && 
                    incoming().seekerId == request.auth.uid &&
                    existsAfter(/databases/$(database)/documents/requests/$(incoming().requestId)) &&
                    getAfter(/databases/$(database)/documents/requests/$(incoming().requestId)).data.status == 'completed';
    }

    function isValidReview(data) {
      return data.requestId is string && data.providerId is string && data.seekerId is string &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             (data.comment == null || (data.comment is string && data.comment.size() <= 1000));
    }
  }
}
